# Postgres connection (sync driver — Alembic uses psycopg)
DATABASE_URL=postgresql+psycopg://me:me@localhost:5434/me

# Environment: dev | test | prod (selects logging renderer + safety defaults)
ENV=dev

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Auth
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-32-bytes-min
# Owner is created out-of-band via the CLI — passphrase is never stored in env:
#   uv run python -m app.cli create-owner            # prompts (no echo)
#   uv run python -m app.cli create-owner "phrase"   # arg form (avoid in shell history)

# LLM (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=

# Memory backend (Supermemory)
# Sign up at https://supermemory.ai. See SUPERMEMORY_SETUP.md.
SUPERMEMORY_API_KEY=
SUPERMEMORY_BASE_URL=https://api.supermemory.ai
SUPERMEMORY_TIMEOUT_MS=2000

# Push (FCM) — stub in dev, real key in prod
FCM_SERVER_KEY=

# Object storage: "local" (dev) or "supabase" (prod)
IMAGE_STORAGE_BACKEND=local

# Supabase (only required when IMAGE_STORAGE_BACKEND=supabase or in prod)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
