# Postgres connection (async driver)
DATABASE_URL=postgresql+asyncpg://me:me@localhost:5432/me

# Auth
JWT_SECRET=change-me

# LLM (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=

# Push (FCM) — stub in dev, real key in prod
FCM_SERVER_KEY=

# Object storage: "local" (dev) or "supabase" (prod)
IMAGE_STORAGE_BACKEND=local

# Supabase (only required when IMAGE_STORAGE_BACKEND=supabase or in prod)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
