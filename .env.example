# Postgres connection (sync driver — Alembic uses psycopg)
DATABASE_URL=postgresql+psycopg://me:me@localhost:5434/me

# Environment: dev | test | prod (selects logging renderer + safety defaults)
ENV=dev

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Auth
JWT_SECRET=change-me

# LLM (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=

# Push (FCM) — stub in dev, real key in prod
FCM_SERVER_KEY=

# Object storage: "local" (dev) or "supabase" (prod)
IMAGE_STORAGE_BACKEND=local

# Supabase (only required when IMAGE_STORAGE_BACKEND=supabase or in prod)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
