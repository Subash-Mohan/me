# Copy this file to /etc/me/env on the VPS, chmod 600, chown root:root.
# Never commit a real env file. Generate JWT_SECRET with: openssl rand -hex 32

# --- Database (managed Postgres connection string) ---------------------------
DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/me?sslmode=require

# --- App environment ---------------------------------------------------------
ENV=prod
LOG_LEVEL=INFO

# --- Auth --------------------------------------------------------------------
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_EXPIRES_DAYS=30
AUTH_RATE_LIMIT_FAILURES=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_LOCK_SECONDS=900

# true because Caddy on the host forwards X-Forwarded-For from real clients.
# Never set to true when the API port is reachable directly from the internet.
TRUST_PROXY_HEADERS=true

# --- Supermemory -------------------------------------------------------------
SUPERMEMORY_API_KEY=replace-me
SUPERMEMORY_BASE_URL=https://api.supermemory.ai
SUPERMEMORY_TIMEOUT_MS=2000

# --- OpenRouter --------------------------------------------------------------
OPENROUTER_API_KEY=replace-me
OPENROUTER_DEFAULT_MODEL=replace-me

# --- Chat --------------------------------------------------------------------
CHAT_HISTORY_TURNS=10
